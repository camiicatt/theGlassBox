cat > .gitignore <<'EOF'
# OS / Editor
.DS_Store
.vscode/
.idea/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.pyc
.venv/
venv/


# Jupyter
.ipynb_checkpoints/

# Build / dist
dist/
build/
out/

# Large / generated / data (edit as needed)
*.zip
*.tar
*.gz
*.7z
*.mp4
*.mov
*.pt
*.pth
*.onnx
*.pkl
*.sqlite
*.db
EOF